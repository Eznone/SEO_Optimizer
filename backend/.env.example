# Django Core Settings
SECRET_KEY="Place Django Secret Key here"
DEBUG="True or False"
ALLOWED_HOSTS="localhost,127.0.0.1,your-domain.com"
SITE_ID="1"
FRONTEND_URL="http://localhost:3000"

# Security & CORS
CSRF_TRUSTED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.com"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.com"

# Database Settings
# For SQLite (default): sqlite:///db.sqlite3
# For Postgres: postgres://user:password@localhost:5432/dbname
DATABASE_URL="sqlite:///db.sqlite3"

# Security (django-encrypted-model-fields)
# Generate with: from encrypted_model_fields.utils import generate_encryption_key; print(generate_encryption_key())
FIELD_ENCRYPTION_KEY="Place Field Encryption Key here"

# Celery / Redis
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://127.0.0.1:6379/0"

# LLM / AI APIs
GROQ_API_KEY="Place Groq API Key here"

# Email Settings (Optional)
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_PORT="587"
# EMAIL_HOST_USER="your-email@gmail.com"
# EMAIL_HOST_PASSWORD="your-app-password"
# EMAIL_USE_TLS="True"

# Social Auth (OAuth)
# GOOGLE_CLIENT_ID="Place Google Client ID here"
# GOOGLE_CLIENT_SECRET="Place Google Client Secret here"
# GITHUB_CLIENT_ID="Place GitHub Client ID here"
# GITHUB_CLIENT_SECRET="Place GitHub Client Secret here"
